# Copy to .env and fill in. .env is gitignored — never commit real values.
# Load with:  set -a; source .env; set +a
#
# Environment variables only (§A.11). Nothing reads this file from Python;
# the shell sources it and the code sees os.environ.

# Bearer token for both the Portal API and the Registry API.
# Requires designer or owner role in the SwaggerHub organisation.
SWAGGERHUB_API_KEY=

# Identifies the target portal — used to resolve it via GET /portals?subdomain=
PORTAL_SUBDOMAIN=

# Trial organisation name. Used only by the seed fixture utility (§A.16),
# which calls the Registry API at https://api.swaggerhub.com
SWAGGERHUB_ORG=
