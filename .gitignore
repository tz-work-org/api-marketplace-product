# Secrets — never commit. See .env.example for the variable names.
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# Local-only working material. Never committed — this repository is public.
# Holds the build context document and the §A.2 / §A.16 verification reports,
# which stay on the author's machine.
.local/

# Claude Code session files, local settings, and project instructions. These
# stay on the author's machine and are never pushed. Ignored explicitly here
# rather than relying on a machine's global gitignore, so the rule travels
# with the repo.
.claude/
CLAUDE.md

# macOS
.DS_Store
